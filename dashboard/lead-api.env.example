# Cloudflare Pages — Lead API environment variables
# Set these in Cloudflare Dashboard → Pages → paradise-spas → Settings → Environment variables
# Do NOT commit real values to git.

GHL_API_TOKEN=pit-your-token-here
GHL_LOCATION_ID=NpZCArkZIoHhOIl8Qjd1

GOOGLE_SHEETS_ID=your_google_sheet_id
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-sa@project.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

ALERT_EMAIL=you@example.com
ALLOWED_ORIGIN=https://www.paradisespas.com

# Optional — recommended before public traffic
TURNSTILE_SECRET_KEY=your_turnstile_secret
RESEND_API_KEY=re_your_resend_key
ALERT_FROM=Paradise Spas <leads@paradisespas.com>

# Optional — Meta Conversions API (see dashboard/META_CAPI_SETUP.md)
META_CAPI_ACCESS_TOKEN=EAAyour_token_here
META_PIXEL_ID=1317738110513512
